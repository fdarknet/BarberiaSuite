{
  "name": "barberia-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev --name init --skip-seed",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "postinstall": "node scripts/ensure-env.mjs",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "db:migrate:new": "prisma migrate dev --skip-seed --name update",
    "prisma:format": "prisma format",
    "db:seed:min": "tsx prisma/seed-minimal.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jimp": "^0.22.12",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "prisma": "^5.20.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "@types/node": "^20.14.10",
    "@types/multer": "^1.4.12"
  }
}
