generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum AppointmentStatus {
  RESERVED
  CONFIRMED
  IN_CHAIR
  COMPLETED
  CANCELED
  NO_SHOW
}

enum PaymentMethod {
  QR
  CASH
  MIXED
}

enum PaymentStatus {
  PENDING
  PAID
  VOID
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  IN
  OUT
}

enum QueueStatus {
  WAITING
  CALLED
  IN_CHAIR
  DONE
  CANCELED
}

enum StoreOrderStatus {
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELED
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())

  branches  Branch[]
  users     User[]
  services  Service[]
  payments  Payment[]
  cashSessions CashSession[]
  queueTickets QueueTicket[]
  products  Product[]
  productSales ProductSale[]
  storeOrders StoreOrder[]
}

model Branch {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  address   String?
  timezone  String   @default("America/La_Paz")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  staff     StaffProfile[]
  branchServices BranchService[]
  appointments   Appointment[]
  payments       Payment[]
  cashSessions   CashSession[]
  queueTickets   QueueTicket[]
  productSales   ProductSale[]

  @@index([orgId])
}

model User {
  id        String   @id @default(cuid())
  orgId     String
  role      Role
  email     String   @unique
  phone     String?
  passwordHash String
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  customer  CustomerProfile?
  staff     StaffProfile?
  voidedPayments Payment[] @relation("payment_voided_by")
  productSales ProductSale[] @relation("product_sale_sold_by")


  cashOpened CashSession[] @relation("cash_opened_by")
  cashClosed CashSession[] @relation("cash_closed_by")

  @@index([orgId])
}

model CustomerProfile {
  id        String @id @default(cuid())
  userId    String @unique
  fullName  String
  whatsappOptIn Boolean @default(false)
  preferredChannel String @default("both") // email|whatsapp|both
  loyaltyPoints Int @default(0)

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  payments Payment[]
}

model StaffProfile {
  id        String @id @default(cuid())
  userId    String @unique
  branchId  String
  displayName String
  photoUrl  String?
  commissionPct Int @default(50)

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  services  StaffService[]
  availability StaffAvailability[]
  appointments Appointment[]
  payments   Payment[]
  queueTickets QueueTicket[]
  commissions CommissionRecord[]

  @@index([branchId])
}

model Service {
  id        String @id @default(cuid())
  orgId     String
  name      String
  durationMin Int
  basePrice Int
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branchServices BranchService[]
  staffServices  StaffService[]
  appointments   Appointment[]
  payments       Payment[]
  queueTickets   QueueTicket[]

  @@unique([orgId, name])
  @@index([orgId])
}

model BranchService {
  id        String @id @default(cuid())
  branchId  String
  serviceId String
  enabled   Boolean @default(true)
  priceOverride Int?

  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([branchId, serviceId])
  @@index([branchId])
}

model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([staffId])
}

model StaffAvailability {
  id       String @id @default(cuid())
  staffId  String
  weekday  Int // 0=Sunday ... 6=Saturday
  startTime String // "09:00"
  endTime   String // "19:00"
  breaks    Json   @default("[]") // [{start:"13:00", end:"14:00"}]

  staff    StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, weekday])
  @@index([staffId, weekday])
}

model Appointment {
  id        String @id @default(cuid())
  orgId     String
  branchId  String
  serviceId String
  staffId   String
  customerId String

  startAt   DateTime
  endAt     DateTime
  status    AppointmentStatus @default(RESERVED)
  price     Int @default(0)
  notes     String?
  createdAt DateTime @default(now())

  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  customer  CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payment   Payment?
  queueTicket QueueTicket?

  @@index([branchId, startAt])
  @@index([staffId, startAt])
}


model Payment {
  id           String @id @default(cuid())
  orgId        String
  branchId     String
  appointmentId String @unique
  customerId   String
  staffId      String
  serviceId    String
  method       PaymentMethod
  amountTotal  Int
  amountCash   Int @default(0)
  amountQr     Int @default(0)
  qrReference  String?
  status       PaymentStatus @default(PAID)
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())
  cashSessionId String?
  voidedAt     DateTime?
  voidedByUserId String?
  voidReason   String?

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff       StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  voidedBy    User? @relation("payment_voided_by", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  commissions CommissionRecord[]

  @@index([branchId, paidAt])
  @@index([staffId, paidAt])
}

model CommissionRecord {
  id        String @id @default(cuid())
  paymentId String
  staffId   String
  pct       Int
  amount    Int
  createdAt DateTime @default(now())

  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, createdAt])
  @@index([paymentId])
}

model CashSession {
  id            String @id @default(cuid())
  orgId         String
  branchId      String
  openedByUserId String
  openedAt      DateTime @default(now())
  openingCash   Int @default(0)
  status        CashSessionStatus @default(OPEN)
  closedByUserId String?
  closedAt      DateTime?
  closingCashCounted Int?
  notes         String?
  createdAt     DateTime @default(now())

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedBy      User @relation("cash_opened_by", fields: [openedByUserId], references: [id], onDelete: Cascade)
  closedBy      User? @relation("cash_closed_by", fields: [closedByUserId], references: [id], onDelete: SetNull)

  movements     CashMovement[]
  payments      Payment[]
  productSales  ProductSale[]

  @@index([branchId, status])
  @@index([orgId])
}

model Product {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  code      String
  price     Int
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  saleItems ProductSaleItem[]
  orderItems StoreOrderItem[]

  @@unique([orgId, code])
  @@index([orgId, active])
}

model StoreOrder {
  id            String @id @default(cuid())
  orgId         String
  customerName  String
  customerPhone String
  notes         String?
  amountTotal   Int
  status        StoreOrderStatus @default(PENDING_PAYMENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  items         StoreOrderItem[]

  @@index([orgId, createdAt])
  @@index([orgId, status])
}

model StoreOrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int
  subtotal  Int

  order     StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model ProductSale {
  id            String        @id @default(cuid())
  orgId         String
  branchId      String
  soldByUserId  String
  method        PaymentMethod
  amountTotal   Int
  amountCash    Int           @default(0)
  amountQr      Int           @default(0)
  notes         String?
  cashSessionId String?
  soldAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  soldBy        User          @relation("product_sale_sold_by", fields: [soldByUserId], references: [id], onDelete: Cascade)
  cashSession   CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  items         ProductSaleItem[]

  @@index([branchId, soldAt])
  @@index([orgId, soldAt])
  @@index([soldByUserId, soldAt])
}

model ProductSaleItem {
  id        String @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Int
  subtotal  Int

  sale      ProductSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
}

model CashMovement {
  id        String @id @default(cuid())
  sessionId String
  type      CashMovementType
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model QueueTicket {
  id          String @id @default(cuid())
  orgId       String
  branchId    String
  ticketNumber Int
  customerName String
  serviceId   String
  staffId     String?
  status      QueueStatus @default(WAITING)
  notes       String?
  createdAt   DateTime @default(now())
  calledAt    DateTime?
  startedAt   DateTime?
  doneAt      DateTime?
  appointmentId String? @unique

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff       StaffProfile? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([branchId, status])
}
